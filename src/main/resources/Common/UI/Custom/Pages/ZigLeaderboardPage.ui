$C = "../Common.ui";
$F = "../Common/ZigFrames.ui";
$M = "../Common/ZigButtons.ui";

// Generic leaderboard page (com.ziggfreed.common.instance.leaderboard.LeaderboardPage):
// an optional PRIMARY tab row (#GroupBar, difficulty) over the SECONDARY tab row (#TabBar,
// party size), a sort toggle (#SortGroup) + Rankings/Stats view toggle (#ViewGroup), a
// Rankings column header (#TableHeader) OR a Stats column header (#StatsHeader), a scrollable
// list (Pages/ZigLeaderboardRow.ui / ZigLeaderboardStatsRow.ui), and a "your rank" footer.
// Shipped once in ziggfreed-common; neutral Zig* ids. Smoke-test in-game.

$C.@PageOverlay {}
$F.@ZigDecoratedFrame {
  @CloseButton = true;
  Anchor: (Width: 860, Height: 700);

  #Content {
    Label #Title {
      Text: "";
      Anchor: (Height: 30, Bottom: 8);
      Style: (FontSize: 20, TextColor: #ffd97a, RenderBold: true);
    }

    // "Which leaderboard" selectors: a primary axis (difficulty) over a secondary axis (party size),
    // each with a leading label so the row's purpose is unambiguous.
    Group #GroupRow {
      LayoutMode: Left;
      Anchor: (Height: 34, Bottom: 6);
      Label #GroupLabel { Anchor: (Width: 84); Padding: (Left: 2); Visible: false; Text: ""; Style: (FontSize: 12, TextColor: #8696a8, VerticalAlignment: Center); }
      Group #GroupBar { FlexWeight: 1; LayoutMode: Left; }
    }

    Group #TabRow {
      LayoutMode: Left;
      Anchor: (Height: 34, Bottom: 8);
      Label #TabLabel { Anchor: (Width: 84); Padding: (Left: 2); Visible: false; Text: ""; Style: (FontSize: 12, TextColor: #8696a8, VerticalAlignment: Center); }
      Group #TabBar { FlexWeight: 1; LayoutMode: Left; }
    }

    // Divider: separates "which leaderboard" (above) from "how it is shown" (below).
    Group { Anchor: (Height: 1, Bottom: 8); Background: #1e2a36; }

    // "How it is shown" controls: the sort metric (left) and the Rankings/Stats view (right edge).
    Group #ControlBar {
      LayoutMode: Left;
      Anchor: (Height: 30, Bottom: 10);

      Label #SortLabel { Anchor: (Width: 48); Padding: (Left: 2); Visible: false; Text: ""; Style: (FontSize: 12, TextColor: #8696a8, VerticalAlignment: Center); }
      Group #SortGroup {
        LayoutMode: Left;
        FlexWeight: 1;
        TextButton #SortBest  { Anchor: (Width: 108, Right: 6); Text: ""; Style: $M.@ZigTabBtnStyle; }
        TextButton #SortTotal { Anchor: (Width: 108, Right: 6); Text: ""; Style: $M.@ZigTabBtnStyle; }
        TextButton #SortTime  { Anchor: (Width: 108, Right: 6); Text: ""; Style: $M.@ZigTabBtnStyle; }
      }

      Label #ViewLabel { Anchor: (Width: 44); Text: ""; Visible: false; Style: (FontSize: 12, TextColor: #8696a8, VerticalAlignment: Center, HorizontalAlignment: End); }
      Group #ViewGroup {
        LayoutMode: Left;
        Anchor: (Width: 226);
        TextButton #ViewRankings { Anchor: (Width: 108, Right: 6); Text: ""; Style: $M.@ZigTabBtnStyle; }
        TextButton #ViewStats    { Anchor: (Width: 108);          Text: ""; Style: $M.@ZigTabBtnStyle; }
      }
    }

    // Rankings column header.
    Group #TableHeader {
      LayoutMode: Left;
      Anchor: (Height: 22, Bottom: 4);
      Label #HdrRank   { Anchor: (Width: 48);  Padding: (Left: 10); Text: ""; Style: (FontSize: 11, TextColor: #8696a8, VerticalAlignment: Center); }
      Label #HdrPlayer { FlexWeight: 1;        Padding: (Left: 4);  Text: ""; Style: (FontSize: 11, TextColor: #8696a8, VerticalAlignment: Center); }
      Label #HdrTotal  { Anchor: (Width: 100); Text: ""; Style: (FontSize: 11, TextColor: #8696a8, VerticalAlignment: Center, HorizontalAlignment: End); }
      Label #HdrScore  { Anchor: (Width: 90);  Text: ""; Style: (FontSize: 11, TextColor: #8696a8, VerticalAlignment: Center, HorizontalAlignment: End); }
      Label #HdrTime   { Anchor: (Width: 70);  Text: ""; Style: (FontSize: 11, TextColor: #8696a8, VerticalAlignment: Center, HorizontalAlignment: End); }
      Label #HdrPlays  { Anchor: (Width: 60);  Padding: (Right: 10); Text: ""; Style: (FontSize: 11, TextColor: #8696a8, VerticalAlignment: Center, HorizontalAlignment: End); }
    }

    // Stats column header (4 generic stat cells; the page hides the unused ones).
    Group #StatsHeader {
      LayoutMode: Left;
      Visible: false;
      Anchor: (Height: 22, Bottom: 4);
      Label #SHdrRank   { Anchor: (Width: 48);  Padding: (Left: 10); Text: ""; Style: (FontSize: 11, TextColor: #8696a8, VerticalAlignment: Center); }
      Label #SHdrPlayer { FlexWeight: 1;        Padding: (Left: 4);  Text: ""; Style: (FontSize: 11, TextColor: #8696a8, VerticalAlignment: Center); }
      Label #SHdrCol0   { Anchor: (Width: 110); Text: ""; Style: (FontSize: 11, TextColor: #8696a8, VerticalAlignment: Center, HorizontalAlignment: End); }
      Label #SHdrCol1   { Anchor: (Width: 110); Text: ""; Style: (FontSize: 11, TextColor: #8696a8, VerticalAlignment: Center, HorizontalAlignment: End); }
      Label #SHdrCol2   { Anchor: (Width: 110); Text: ""; Style: (FontSize: 11, TextColor: #8696a8, VerticalAlignment: Center, HorizontalAlignment: End); }
      Label #SHdrCol3   { Anchor: (Width: 110); Text: ""; Style: (FontSize: 11, TextColor: #8696a8, VerticalAlignment: Center, HorizontalAlignment: End); }
      Label #SHdrPlays  { Anchor: (Width: 60);  Padding: (Right: 10); Text: ""; Style: (FontSize: 11, TextColor: #8696a8, VerticalAlignment: Center, HorizontalAlignment: End); }
    }

    Group { Anchor: (Height: 1, Bottom: 6); Background: #1e2a36; }

    Group #LeaderboardList {
      FlexWeight: 1;
      LayoutMode: TopScrolling;
      ScrollbarStyle: $C.@DefaultScrollbarStyle;
      Padding: (Right: 4);
    }

    Label #EmptyState {
      Text: "";
      Visible: false;
      Anchor: (Height: 22, Top: 6);
      Style: (FontSize: 13, TextColor: #8696a8, HorizontalAlignment: Center);
    }

    Group { Anchor: (Height: 1, Top: 8); Background: #1e2a36; }
    Label #YourRank {
      Text: "";
      Anchor: (Height: 24, Top: 6);
      Style: (FontSize: 13, TextColor: #ffd97a, VerticalAlignment: Center, HorizontalAlignment: Center);
    }
  }
}
