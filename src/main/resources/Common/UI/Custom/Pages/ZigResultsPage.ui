$C = "../Common.ui";
$F = "../Common/ZigFrames.ui";
$M = "../Common/ZigButtons.ui";

// Generic end-of-game results screen (com.ziggfreed.common.instance.result.ResultsPage):
// outcome header, team-grouped per-player rows (Pages/ZigResultRow.ui), the viewer's
// score-column breakdown, the reward strip (Pages/ZigResultChip.ui), and footer CTAs.
// Shipped once in ziggfreed-common; neutral Zig* ids. Smoke-test in-game.

$C.@PageOverlay {}
$F.@ZigDecoratedFrame {
  @CloseButton = true;
  Anchor: (Width: 660, Height: 640);

  #Content {
    Label #OutcomeTitle {
      Text: "";
      Anchor: (Height: 34, Bottom: 2);
      Style: (FontSize: 24, TextColor: #ffd700, RenderBold: true, HorizontalAlignment: Center);
    }
    Label #Duration {
      Text: "";
      Anchor: (Height: 18, Bottom: 8);
      Style: (FontSize: 12, TextColor: #8696a8, HorizontalAlignment: Center);
    }

    Group { Anchor: (Height: 1, Bottom: 8); Background: #1e2a36; }

    // Team-grouped per-player rows.
    Group #ResultsList {
      Anchor: (Height: 220, Bottom: 10);
      LayoutMode: TopScrolling;
      ScrollbarStyle: $C.@DefaultScrollbarStyle;
      Padding: (Right: 4);
    }

    Label #BreakdownTitle {
      Text: "";
      Anchor: (Height: 20, Bottom: 4);
      Style: (FontSize: 14, TextColor: #ffd97a, RenderBold: true);
    }
    Group #BreakdownList {
      Anchor: (Height: 120, Bottom: 10);
      LayoutMode: TopScrolling;
      ScrollbarStyle: $C.@DefaultScrollbarStyle;
      Padding: (Right: 4);
    }

    Label #RewardsTitle {
      Text: "";
      Anchor: (Height: 20, Bottom: 4);
      Style: (FontSize: 14, TextColor: #ffd97a, RenderBold: true);
    }
    Group #RewardList {
      LayoutMode: Left;
      Anchor: (Height: 30, Bottom: 4);
    }
    Label #NoRewards {
      Text: "";
      Visible: false;
      Anchor: (Height: 18, Bottom: 4);
      Style: (FontSize: 12, TextColor: #8696a8);
    }
    Label #PendingNote {
      Text: "";
      Visible: false;
      Anchor: (Height: 18, Bottom: 6);
      Style: (FontSize: 11, TextColor: #e0a030);
    }

    // Footer CTAs.
    Group #FooterRow {
      LayoutMode: Left;
      Anchor: (Height: 36, Top: 8);
      TextButton #ViewLbBtn    { FlexWeight: 1; Anchor: (Height: 36); Style: $M.@ZigOptionBtnStyle; Visible: false; }
      TextButton #PlayAgainBtn { FlexWeight: 1; Anchor: (Height: 36, Left: 6); Style: $M.@ZigOptionBtnStyle; Visible: false; }
    }
  }
}
