$C = "../Common.ui";

// One reward chip (appended into #RewardList; see ResultsPage). A pill with an optional 22px
// item icon (set from Java by item id via #ChipIcon.Slots - a DATA property, settable, unlike a
// texture path which would render a red X) + a label whose text carries the amount + name
// ("Moonbloom x2", auto-generated by RewardChipRenderer). The icon defaults hidden; ResultsPage
// reveals + fills it only for ITEM rewards (a currency / command chip stays text-only). A pending
// (blocked) chip is tinted from Java.
@ZigChipIconStyle = ItemGridStyle(
  SlotSize: 22,
  SlotIconSize: 20,
  SlotSpacing: 0,
  SlotBackground: "../Common/ContainerPanelPatch.png",
  QuantityPopupSlotOverlay: "../Common/ContainerPanelPatch.png",
  BrokenSlotBackgroundOverlay: "../Common/ContainerPanelPatch.png",
  BrokenSlotIconOverlay: "../Common/ContainerPanelPatch.png",
  DefaultItemIcon: "../Common/ContainerPanelPatch.png",
  DurabilityBar: "../Common/ContainerPanelPatch.png",
  DurabilityBarBackground: "../Common/ContainerPanelPatch.png",
  DurabilityBarAnchor: (Bottom: 0, Left: 0, Width: 0, Height: 0),
  DurabilityBarColorStart: #a63232,
  DurabilityBarColorEnd: #63b649,
  CursedIconPatch: "../Common/ContainerPanelPatch.png",
  CursedIconAnchor: (Bottom: 0, Left: 0, Width: 0, Height: 0)
);

Group #ZigResultChip {
  Anchor: (Height: 28, Width: 168, Right: 6, Bottom: 4);
  Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);
  Padding: (Horizontal: 6);
  LayoutMode: Left;

  ItemGrid #ChipIcon {
    Visible: false;
    Anchor: (Width: 22, Height: 22, Right: 4, Top: 3);
    SlotsPerRow: 1;
    AreItemsDraggable: false;
    DisplayItemQuantity: false;
    Style: @ZigChipIconStyle;
  }

  Label #ChipLabel {
    FlexWeight: 1;
    Text: "";
    Style: (FontSize: 12, TextColor: #cfe3c0, VerticalAlignment: Center, HorizontalAlignment: Center);
  }
}
