$C = "../Common.ui";

// ── ziggfreed-common appendable SETTINGS-FORM dropdown row ────────────────────
// Appended by SettingsForm.buildRows into a consumer's list container:
//   cmd.append("#MyForm", "Pages/ZigFormDropdownRow.ui");
// then addressed by the INDEXED PARENT (e.g. "#MyForm[0] #Dropdown"), so the bare
// descendant ids below are safe across many rows AND across mods (the ZigListRow rule).
//
// The TRISTATE/DROPDOWN row: a flexing label (#Title) plus a fixed-width dropdown
// (#Dropdown), entries populated from Java via SettingsUiUtil.populate. A white,
// non-uppercase label style keeps it readable against the dark settings background.
// #Row wraps the control line (LayoutMode: Left) so an optional #Hint sub-label can
// sit below it (LayoutMode: Top on the root); #Hint starts hidden and collapses to
// zero height until SettingsForm.buildRows/applyHint paints + shows it.

@DropStyle = DropdownBoxStyle(
  ...$C.@DefaultDropdownBoxStyle,
  LabelStyle: (...$C.@DefaultDropdownBoxLabelStyle, TextColor: #ffffff, RenderUppercase: false)
);

Group #ZigFormDropdownRow {
  LayoutMode: Top;
  Anchor: (Bottom: 5);

  Group #Row {
    LayoutMode: Left;
    Anchor: (Height: 32);

    Label #Title {
      FlexWeight: 1;
      Text: "";
      Style: (FontSize: 13, TextColor: #cdd8e6, VerticalAlignment: Center);
    }

    $C.@DropdownBox #Dropdown {
      Anchor: (Width: 190, Height: 30);
      Style: @DropStyle;
    }
  }

  Label #Hint {
    Visible: false;
    Text: "";
    Padding: (Right: 96);
    Style: (FontSize: 11, TextColor: #8696a8, Wrap: true);
  }
}
