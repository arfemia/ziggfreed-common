$C = "../Common.ui";

// One ranked leaderboard row (appended into #LeaderboardList; see LeaderboardPage):
// Rank / Player / Score / Time / Plays. Medal ranks + the viewer's row are tinted from
// Java. Colour-only.

Group #ZigLeaderboardRow {
  LayoutMode: Left;
  Anchor: (Height: 28, Bottom: 2);

  Label #Rank   { Anchor: (Width: 48);  Padding: (Left: 10); Text: ""; Style: (FontSize: 13, TextColor: #d7e4f0, VerticalAlignment: Center, RenderBold: true); }
  Label #Player { FlexWeight: 1;        Padding: (Left: 4);  Text: ""; Style: (FontSize: 13, TextColor: #d7e4f0, VerticalAlignment: Center); }
  Label #Score  { Anchor: (Width: 90);  Text: ""; Style: (FontSize: 13, TextColor: #cfe3c0, VerticalAlignment: Center, HorizontalAlignment: End); }
  Label #Time   { Anchor: (Width: 70);  Text: ""; Style: (FontSize: 13, TextColor: #b6c9de, VerticalAlignment: Center, HorizontalAlignment: End); }
  Label #Plays  { Anchor: (Width: 60);  Padding: (Right: 10); Text: ""; Style: (FontSize: 13, TextColor: #8696a8, VerticalAlignment: Center, HorizontalAlignment: End); }
}
