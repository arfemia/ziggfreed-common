$Z = "../Common/ZigButtons.ui";

// ── ziggfreed-common appendable SETTINGS-FORM toggle row ──────────────────────
// Appended by SettingsForm.buildRows into a consumer's list container:
//   cmd.append("#MyForm", "Pages/ZigFormToggleRow.ui");
// then addressed by the INDEXED PARENT (e.g. "#MyForm[0] #Toggle"), so the bare
// descendant ids below are safe across many rows AND across mods (the ZigListRow rule).
//
// The TOGGLE row: a flexing label (#Title) plus an instant on/off button (#Toggle).
// #Toggle's OWN inner #Label (On/Off state text) is what SettingsUiUtil.setToggle
// paints - the row label stays #Title so the two ids never collide.

Group #ZigFormToggleRow {
  LayoutMode: Left;
  Anchor: (Height: 32, Bottom: 5);

  Label #Title {
    FlexWeight: 1;
    Text: "";
    Style: (FontSize: 13, TextColor: #cdd8e6, VerticalAlignment: Center);
  }

  Button #Toggle {
    Style: $Z.@ZigRichRowBtnStyle;
    Anchor: (Width: 96, Height: 30);
    Label #Label {
      FlexWeight: 1;
      Text: "";
      Style: (FontSize: 13, TextColor: #e6eef7, HorizontalAlignment: Center, VerticalAlignment: Center);
    }
  }
}
