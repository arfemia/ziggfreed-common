$C = "../Common.ui";
$F = "../Common/ZigFrames.ui";
$M = "../Common/ZigButtons.ui";

// Generic queue / "ready" screen (com.ziggfreed.common.instance.queue.QueuePage). The
// player stays on this after queueing; Close keeps the queue reservation, Leave de-queues.
// Roster rows are appended from Java (Pages/ZigQueueRosterRow.ui). Shipped once in
// ziggfreed-common; neutral Zig* ids. Smoke-test in-game (.ui is not gradle-validated).

$C.@PageOverlay {}
$F.@ZigDecoratedFrame {
  @CloseButton = true;
  Anchor: (Width: 520, Height: 520);

  #Content {
    Label #Title {
      Text: "";
      Anchor: (Height: 30, Bottom: 6);
      Style: (FontSize: 20, TextColor: #ffd97a, RenderBold: true);
    }
    Label #PlayerCount {
      Text: "";
      Anchor: (Height: 20, Bottom: 4);
      Style: (FontSize: 14, TextColor: #d7e4f0);
    }
    Label #Status {
      Text: "";
      Anchor: (Height: 20, Bottom: 4);
      Style: (FontSize: 14, TextColor: #5ab0ff, RenderBold: true);
    }
    Label #WaitEstimate {
      Text: "";
      Anchor: (Height: 18, Bottom: 8);
      Style: (FontSize: 11, TextColor: #8696a8);
    }

    Group { Anchor: (Height: 1, Bottom: 8); Background: #1e2a36; }

    Group #RosterList {
      FlexWeight: 1;
      LayoutMode: TopScrolling;
      ScrollbarStyle: $C.@DefaultScrollbarStyle;
      Padding: (Right: 4);
    }

    Group #FooterRow {
      LayoutMode: Left;
      Anchor: (Height: 36, Top: 8);
      TextButton #RefreshBtn { FlexWeight: 1; Anchor: (Height: 36); Style: $M.@ZigOptionBtnStyle; Visible: false; }
      TextButton #LeaveBtn   { FlexWeight: 1; Anchor: (Height: 36, Left: 6); Style: $M.@ZigOptionBtnStyle; Visible: false; }
    }
  }
}
